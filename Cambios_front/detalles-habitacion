<!DOCTYPE html>
<html class="light" lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Detalles de Habitación | Cusco Rent</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .fill-icon {
            font-variation-settings: 'FILL' 1;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f9f9f9;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #dac2ae;
            border-radius: 10px;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-error": "#ffffff",
                        "surface-dim": "#dadad9",
                        "on-secondary-fixed-variant": "#004c69",
                        "on-tertiary-fixed": "#2c1600",
                        "tertiary-container": "#efa655",
                        "outline-variant": "#dac2ae",
                        "secondary-container": "#40c2fd",
                        "surface-card": "#ffffff",
                        "tertiary": "#895100",
                        "secondary-fixed-dim": "#7bd0ff",
                        "tertiary-fixed-dim": "#ffb86c",
                        "surface-container-low": "#f4f3f3",
                        "secondary-fixed": "#c4e7ff",
                        "tertiary-fixed": "#ffdcbc",
                        "primary-fixed-dim": "#ffb86b",
                        "on-primary-fixed-variant": "#683d00",
                        "icon-blue": "#38BDF8",
                        "outline-muted": "#dac2ae",
                        "on-tertiary-container": "#683c00",
                        "inverse-primary": "#ffb86b",
                        "primary": "#895100",
                        "error": "#ba1a1a",
                        "surface-container-highest": "#e2e2e2",
                        "surface-container": "#eeeeee",
                        "surface-container-lowest": "#ffffff",
                        "surface-tint": "#895100",
                        "surface-container-high": "#e8e8e8",
                        "on-secondary-fixed": "#001e2c",
                        "surface-bg": "#f9f9f9",
                        "secondary": "#00668a",
                        "error-container": "#ffdad6",
                        "on-primary": "#ffffff",
                        "on-primary-fixed": "#2c1700",
                        "surface": "#f9f9f9",
                        "outline": "#877462",
                        "surface-bright": "#f9f9f9",
                        "surface-variant": "#e2e2e2",
                        "inverse-surface": "#2f3131",
                        "primary-fixed": "#ffdcbc",
                        "on-surface-variant": "#544434",
                        "on-secondary-container": "#004d6a",
                        "on-surface": "#1a1c1c",
                        "inverse-on-surface": "#f1f1f0",
                        "on-secondary": "#ffffff",
                        "on-primary-container": "#683c00",
                        "primary-container": "#ff9f1c",
                        "on-tertiary-fixed-variant": "#683c00",
                        "on-background": "#1a1c1c",
                        "on-tertiary": "#ffffff",
                        "background": "#f9f9f9",
                        "on-error-container": "#93000a"
                    },
                    "borderRadius": {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "16px",
                        "chassis-padding": "12px",
                        "stack-sm": "8px",
                        "stack-lg": "24px",
                        "stack-md": "16px",
                        "screen-margin": "20px"
                    },
                    "fontFamily": {
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-lg-mobile": ["Plus Jakarta Sans"],
                        "body-md": ["Plus Jakarta Sans"],
                        "headline-md": ["Plus Jakarta Sans"],
                        "headline-lg": ["Plus Jakarta Sans"],
                        "label-lg": ["Plus Jakarta Sans"],
                        "label-sm": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "30px", "letterSpacing": "-0.01em", "fontWeight": "700" }],
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-md": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "headline-lg": ["30px", { "lineHeight": "38px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "label-lg": ["14px", { "lineHeight": "18px", "letterSpacing": "0.01em", "fontWeight": "600" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
</head>

<body class="bg-surface text-on-surface">

    <nav
        class="flex justify-between items-center px-screen-margin py-stack-sm w-full sticky top-0 z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant">
        <div class="font-headline-md text-headline-md font-bold text-primary">Cusco Rent</div>
        <div class="hidden md:flex items-center gap-stack-lg">
            <a class="font-body-lg text-body-lg text-primary font-bold border-b-2 border-primary hover:text-primary transition-colors"
                href="#">Explorar</a>
            <a class="font-body-lg text-body-lg text-on-surface-variant hover:text-primary transition-colors"
                href="#">Favoritos</a>
            <a class="font-body-lg text-body-lg text-on-surface-variant hover:text-primary transition-colors"
                href="#">Mensajes</a>
        </div>
        <div class="flex items-center gap-stack-md">
            <div class="hidden md:block bg-surface-container-low rounded-full px-4 py-2 border border-outline-variant">
                <div class="flex items-center gap-2 text-on-surface-variant">
                    <span class="material-symbols-outlined text-[20px]">search</span>
                    <span class="text-label-lg">Buscar alojamiento...</span>
                </div>
            </div>
            <button class="scale-95 active:opacity-80 transition-all text-on-surface-variant">
                <span class="material-symbols-outlined text-[32px]">account_circle</span>
            </button>
        </div>
    </nav>

    <main class="max-w-[1440px] mx-auto px-screen-margin py-stack-lg">

        <section id="galeria-habitacion"
            class="grid grid-cols-4 grid-rows-2 gap-4 h-[500px] mb-stack-lg rounded-lg overflow-hidden bg-surface-container-high">
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

            <div class="lg:col-span-8 space-y-8">

                <div class="border-b border-outline-variant pb-8">
                    <div class="flex justify-between items-start gap-4 mb-2">
                        <div>
                            <h1 id="detalle-titulo" class="font-headline-lg text-headline-lg text-on-surface mb-2">
                            </h1>
                            <div class="flex items-center gap-2 text-on-surface-variant font-body-lg">
                                <span class="material-symbols-outlined text-[20px]">location_on</span>
                                <span id="detalle-ubicacion"></span>
                            </div>
                        </div>
                        <div id="badge-verificado" class="flex flex-col items-end hidden">
                            <span
                                class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full font-label-lg flex items-center gap-1">
                                <span class="material-symbols-outlined text-[18px] fill-icon">verified</span> Verificado
                            </span>
                        </div>
                    </div>

                    <div id="detalle-comodidades" class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
                    </div>
                </div>

                <div
                    class="flex items-center gap-4 p-6 bg-surface-container-lowest border border-outline-variant rounded-lg">
                    <div id="avatar-arrendador"
                        class="w-16 h-16 rounded-full overflow-hidden bg-surface-container-high">
                    </div>
                    <div>
                        <h3 id="nombre-arrendador" class="font-headline-md text-headline-md text-on-surface"></h3>
                        <p id="info-arrendador" class="text-on-surface-variant font-body-md"></p>
                    </div>
                </div>

                <div class="space-y-4">
                    <h2 class="font-headline-md text-headline-md">Acerca de esta habitación</h2>
                    <div id="detalle-descripcion"
                        class="font-body-lg text-on-surface-variant leading-relaxed space-y-4">
                    </div>
                </div>

                <div class="space-y-4 pt-4 border-t border-outline-variant">
                    <h2 class="font-headline-md text-headline-md">Reglas de la casa</h2>
                    <div id="detalle-reglas" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4 space-y-6 lg:sticky lg:top-24">

                <div
                    class="bg-surface-container-lowest rounded-lg border border-outline-variant overflow-hidden shadow-sm">
                    <div class="p-4 border-b border-outline-variant">
                        <h3 class="font-headline-md text-headline-md">Ubicación</h3>
                    </div>
                    <div id="mapa-contenedor"
                        class="h-64 bg-surface-container-high relative group flex items-center justify-center">
                        <button
                            class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-white px-6 py-2 rounded-full shadow-lg font-label-lg text-primary flex items-center gap-2 hover:bg-primary-container hover:text-white transition-all">
                            <span class="material-symbols-outlined text-[20px]">fullscreen</span> Ver Mapa Completo
                        </button>
                    </div>
                </div>

                <div
                    class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 shadow-xl space-y-6">
                    <div class="flex justify-between items-baseline">
                        <div class="flex items-baseline gap-1">
                            <span id="reserva-precio" class="text-headline-lg font-bold text-on-surface"></span>
                            <span class="text-on-surface-variant font-body-md">/ mes</span>
                        </div>
                        <div class="flex items-center gap-1 text-primary">
                            <span class="material-symbols-outlined fill-icon text-[18px]">star</span>
                            <span id="reserva-calificacion" class="font-label-lg"></span>
                            <span id="reserva-resenas" class="text-on-surface-variant text-[12px]"></span>
                        </div>
                    </div>

                    <div
                        class="grid grid-cols-2 border border-outline-variant rounded-DEFAULT overflow-hidden bg-surface-bright">
                        <div class="p-3 border-r border-outline-variant space-y-1">
                            <p class="text-[10px] uppercase font-bold text-on-surface-variant">Ingreso</p>
                            <p id="reserva-fecha" class="font-body-md"></p>
                        </div>
                        <div class="p-3 space-y-1">
                            <p class="text-[10px] uppercase font-bold text-on-surface-variant">Estadía Mín.</p>
                            <p id="reserva-estadia" class="font-body-md"></p>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <button id="btn-pagar"
                            class="w-full bg-primary-container text-on-primary-container h-14 rounded-DEFAULT font-headline-md flex items-center justify-center gap-2 hover:brightness-95 active:scale-[0.98] transition-all">
                            Pagar Mensualidad
                        </button>
                        <button id="btn-contactar"
                            class="w-full border-2 border-primary text-primary h-14 rounded-DEFAULT font-headline-md flex items-center justify-center gap-2 hover:bg-primary-fixed transition-all">
                            <span class="material-symbols-outlined">mail</span> Contactar Propietario
                        </button>
                    </div>

                    <p class="text-center text-on-surface-variant text-label-sm">No se te cobrará nada todavía</p>

                    <div id="reserva-desglose" class="pt-4 border-t border-outline-variant space-y-2">
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer
        class="w-full py-stack-lg px-screen-margin flex flex-col md:flex-row justify-between items-center gap-stack-md bg-surface-container-high border-t border-outline-variant mt-stack-lg">
        <div class="flex flex-col items-center md:items-start gap-1">
            <div class="font-headline-md text-headline-md text-primary font-bold">Cusco Rent</div>
            <p class="font-body-md text-body-md text-on-surface-variant">© 2024 Cusco Rent. Vivienda estudiantil con
                alma andina.</p>
        </div>
        <div class="flex gap-stack-lg">
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container underline transition-all"
                href="#">Nosotros</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container underline transition-all"
                href="#">Términos y Condiciones</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container underline transition-all"
                href="#">Privacidad</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container underline transition-all"
                href="#">Contacto</a>
        </div>
    </footer>

    <script>
        // Micro-interactions for buttons (Delegación de eventos para funcionar con elementos inyectados dinámicamente)
        document.addEventListener('mousedown', (e) => {
            if (e.target.closest('button')) {
                e.target.closest('button').style.transform = 'scale(0.96)';
            }
        });
        document.addEventListener('mouseup', (e) => {
            if (e.target.closest('button')) {
                e.target.closest('button').style.transform = 'scale(1)';
            }
        });
        document.addEventListener('mouseleave', (e) => {
            if (e.target.closest('button')) {
                e.target.closest('button').style.transform = 'scale(1)';
            }
        }, true);
    </script>
</body>

</html>