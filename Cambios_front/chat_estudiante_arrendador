<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Andean Modern - Mensajes</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-container": "#ff9f1c",
                        "error": "#ba1a1a",
                        "on-tertiary-fixed": "#2c1600",
                        "surface-container": "#eeeeed",
                        "tertiary-fixed-dim": "#ffb86c",
                        "on-secondary": "#ffffff",
                        "tertiary-container": "#efa655",
                        "surface-tint": "#895100",
                        "surface-dim": "#dadad9",
                        "outline-variant": "#dac2ae",
                        "surface": "#f9f9f9",
                        "on-tertiary-container": "#683c00",
                        "surface-card": "#ffffff",
                        "on-primary-fixed": "#2c1700",
                        "on-background": "#1a1c1c",
                        "on-error-container": "#93000a",
                        "on-surface-variant": "#544434",
                        "on-secondary-fixed-variant": "#004c69",
                        "on-secondary-container": "#004d6a",
                        "surface-bright": "#f9f9f9",
                        "tertiary-fixed": "#ffdcbc",
                        "outline-muted": "#dac2ae",
                        "on-surface": "#1a1c1c",
                        "inverse-surface": "#2f3131",
                        "outline": "#877462",
                        "inverse-on-surface": "#f1f1f0",
                        "secondary-fixed": "#c4e7ff",
                        "surface-container-highest": "#e2e2e2",
                        "secondary-fixed-dim": "#7bd0ff",
                        "error-container": "#ffdad6",
                        "inverse-primary": "#ffb86b",
                        "primary-fixed-dim": "#ffb86b",
                        "secondary-container": "#40c2fd",
                        "tertiary": "#895100",
                        "surface-variant": "#e2e2e2",
                        "on-secondary-fixed": "#001e2c",
                        "icon-blue": "#38BDF8",
                        "primary-fixed": "#ffdcbc",
                        "background": "#f9f9f9",
                        "on-tertiary-fixed-variant": "#683c00",
                        "surface-container-lowest": "#ffffff",
                        "on-primary-container": "#683c00",
                        "on-tertiary": "#ffffff",
                        "surface-container-high": "#e8e8e8",
                        "primary": "#895100",
                        "on-error": "#ffffff",
                        "surface-container-low": "#f4f3f3",
                        "secondary": "#00668a",
                        "surface-bg": "#f9f9f9",
                        "on-primary-fixed-variant": "#683d00",
                        "on-primary": "#ffffff"
                    },
                    "borderRadius": {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "screen-margin": "20px",
                        "stack-sm": "8px",
                        "stack-lg": "24px",
                        "chassis-padding": "12px",
                        "stack-md": "16px",
                        "gutter": "16px"
                    },
                    "fontFamily": {
                        "headline-lg": ["Plus Jakarta Sans"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-md": ["Plus Jakarta Sans"],
                        "body-md": ["Plus Jakarta Sans"],
                        "label-sm": ["Plus Jakarta Sans"],
                        "label-lg": ["Plus Jakarta Sans"],
                        "headline-lg-mobile": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
