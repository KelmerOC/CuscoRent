<!DOCTYPE html>
<html class="light" lang="es" style="">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Cusco Rent | Encuentra tu hogar estudiantil</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@100..900&display=swap" rel="stylesheet">

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-error": "#ffffff",
                        "surface-dim": "#dadad9",
                        "on-secondary-fixed-variant": "#004c69",
                        "on-tertiary-fixed": "#2c1600",
                        "tertiary-container": "#efa655",
                        "outline-variant": "#dac2ae",
                        "secondary-container": "#40c2fd",
                        "surface-card": "#ffffff",
                        "tertiary": "#895100",
                        "secondary-fixed-dim": "#7bd0ff",
                        "tertiary-fixed-dim": "#ffb86c",
                        "surface-container-low": "#f4f3f3",
                        "secondary-fixed": "#c4e7ff",
                        "tertiary-fixed": "#ffdcbc",
                        "primary-fixed-dim": "#ffb86b",
                        "on-primary-fixed-variant": "#683d00",
                        "icon-blue": "#38BDF8",
                        "outline-muted": "#dac2ae",
                        "on-tertiary-container": "#683c00",
                        "inverse-primary": "#ffb86b",
                        "primary": "#895100",
                        "error": "#ba1a1a",
                        "surface-container-highest": "#e2e2e2",
                        "surface-container": "#eeeeee",
                        "surface-container-lowest": "#ffffff",
                        "surface-tint": "#895100",
                        "surface-container-high": "#e8e8e8",
                        "on-secondary-fixed": "#001e2c",
                        "surface-bg": "#f9f9f9",
                        "secondary": "#00668a",
                        "error-container": "#ffdad6",
                        "on-primary": "#ffffff",
                        "on-primary-fixed": "#2c1700",
                        "surface": "#f9f9f9",
                        "outline": "#877462",
                        "surface-bright": "#f9f9f9",
                        "surface-variant": "#e2e2e2",
                        "inverse-surface": "#2f3131",
                        "primary-fixed": "#ffdcbc",
                        "on-surface-variant": "#544434",
                        "on-secondary-container": "#004d6a",
                        "on-surface": "#1a1c1c",
                        "inverse-on-surface": "#f1f1f0",
                        "on-secondary": "#ffffff",
                        "on-primary-container": "#683c00",
                        "primary-container": "#ff9f1c",
                        "on-tertiary-fixed-variant": "#683c00",
                        "on-background": "#1a1c1c",
                        "on-tertiary": "#ffffff",
                        "background": "#f9f9f9",
                        "on-error-container": "#93000a"
                    },
                    "borderRadius": {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "16px",
                        "chassis-padding": "12px",
                        "stack-sm": "8px",
                        "stack-lg": "24px",
                        "stack-md": "16px",
                        "screen-margin": "20px"
                    },
                    "fontFamily": {
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-lg-mobile": ["Plus Jakarta Sans"],
                        "body-md": ["Plus Jakarta Sans"],
                        "headline-md": ["Plus Jakarta Sans"],
                        "headline-lg": ["Plus Jakarta Sans"],
                        "label-lg": ["Plus Jakarta Sans"],
                        "label-sm": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "30px", "letterSpacing": "-0.01em", "fontWeight": "700" }],
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-md": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "headline-lg": ["30px", { "lineHeight": "38px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "label-lg": ["14px", { "lineHeight": "18px", "letterSpacing": "0.01em", "fontWeight": "600" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #dac2ae;
            border-radius: 10px;
        }

        .map-marker {
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .map-marker:hover {
            transform: scale(1.1) translateY(-4px);
            z-index: 50;
        }
    </style>
</head>

<body
    class="bg-surface font-body-lg text-on-background selection:bg-primary-container selection:text-on-primary-container">

    <nav
        class="flex justify-between items-center px-screen-margin py-stack-sm w-full sticky top-0 z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant">
        <div class="flex items-center gap-stack-md">
            <span class="font-headline-md text-headline-md font-bold text-primary">Cusco Rent</span>
        </div>
        <div class="hidden md:flex items-center gap-stack-lg">
            <a class="font-body-lg text-body-lg text-primary font-bold border-b-2 border-primary transition-all"
                href="#">Explorar</a>
            <a class="font-body-lg text-body-lg text-on-surface-variant hover:text-primary transition-colors"
                href="#">Favoritos</a>
            <a class="font-body-lg text-body-lg text-on-surface-variant hover:text-primary transition-colors"
                href="#">Mensajes</a>
        </div>
        <div class="flex items-center gap-stack-md">
            <div class="relative hidden lg:block">
                <input
                    class="bg-surface-container-low border-none rounded-full px-6 py-2 w-64 focus:ring-2 focus:ring-primary-container font-body-md text-body-md"
                    placeholder="Buscar barrio..." type="text">
                <span
                    class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
            </div>
            <button class="transition-all scale-95 active:opacity-80">
                <span class="material-symbols-outlined text-primary text-3xl">account_circle</span>
            </button>
        </div>
    </nav>

    <main class="flex h-[calc(100vh-64px)] overflow-hidden">

        <section class="w-full lg:w-2/5 flex flex-col bg-white border-r border-outline-variant z-10 relative">

            <div class="p-screen-margin border-b border-outline-variant bg-white/95 backdrop-blur-sm sticky top-0">
                <h1 class="font-headline-md text-headline-md text-on-surface mb-stack-md">Habitaciones en Cusco</h1>
                <div class="flex flex-wrap gap-stack-sm">
                    <button
                        class="px-4 py-2 bg-primary-container text-on-primary-container rounded-full flex items-center gap-2 font-label-lg text-label-lg shadow-sm transition-all hover:brightness-105">
                        <span class="material-symbols-outlined text-[18px]">payments</span> Precio
                    </button>
                    <button
                        class="px-4 py-2 bg-surface-container-low text-on-surface-variant border border-outline-variant rounded-full flex items-center gap-2 font-label-lg text-label-lg hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-[18px]">bed</span> Tipo de Cuarto
                    </button>
                    <button
                        class="px-4 py-2 bg-surface-container-low text-on-surface-variant border border-outline-variant rounded-full flex items-center gap-2 font-label-lg text-label-lg hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-[18px]">group</span> Roommates
                    </button>
                    <button
                        class="p-2 bg-surface-container-low text-on-surface-variant border border-outline-variant rounded-full hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined">tune</span>
                    </button>
                </div>
            </div>

            <div id="catalogo-habitaciones"
                class="flex-1 overflow-y-auto custom-scrollbar p-screen-margin space-y-stack-lg">
            </div>
        </section>

        <section class="hidden lg:block lg:w-3/5 relative bg-surface-container">
            <div class="w-full h-full grayscale opacity-80" data-location="Cusco, Peru"></div>

            <div id="mapa-marcadores" class="absolute inset-0 pointer-events-none">
            </div>

            <div class="absolute right-6 top-6 flex flex-col gap-stack-sm pointer-events-auto">
                <button
                    class="w-12 h-12 bg-white rounded-full shadow-xl flex items-center justify-center hover:bg-surface-container-low transition-all">
                    <span class="material-symbols-outlined text-primary">add</span>
                </button>
                <button
                    class="w-12 h-12 bg-white rounded-full shadow-xl flex items-center justify-center hover:bg-surface-container-low transition-all">
                    <span class="material-symbols-outlined text-primary">remove</span>
                </button>
                <button
                    class="w-12 h-12 bg-white rounded-full shadow-xl flex items-center justify-center hover:bg-surface-container-low transition-all mt-4">
                    <span class="material-symbols-outlined text-primary">my_location</span>
                </button>
            </div>
        </section>
    </main>

    <button
        class="fixed bottom-10 left-1/2 -translate-x-1/2 lg:left-[calc(20%+8px)] lg:translate-x-0 z-50 bg-primary-container text-on-primary-container px-8 py-4 rounded-full font-label-lg text-label-lg flex items-center gap-3 shadow-2xl hover:scale-105 active:scale-95 transition-all">
        <span class="material-symbols-outlined">map</span> Ver Mapa Completo
    </button>

    <footer
        class="w-full py-stack-lg px-screen-margin flex flex-col md:flex-row justify-between items-center gap-stack-md bg-surface-container-high border-t border-outline-variant relative z-40">
        <div class="flex flex-col md:items-start items-center">
            <span class="font-headline-md text-headline-md text-primary font-bold">Cusco Rent</span>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-xs mt-1 text-center md:text-left">© 2024
                Cusco Rent. Vivienda estudiantil con alma andina.</p>
        </div>
        <div class="flex gap-stack-lg">
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container transition-all"
                href="#">Nosotros</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container transition-all"
                href="#">Términos</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container transition-all"
                href="#">Privacidad</a>
            <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary-container transition-all"
                href="#">Contacto</a>
        </div>
    </footer>

    <script>
        // Micro-interactions for map markers (Se aplicará a los inyectados dinámicamente)
        document.addEventListener('click', (e) => {
            const marker = e.target.closest('.map-marker');
            if (marker) {
                // Visual feedback
                marker.classList.toggle('bg-primary-container');
                marker.classList.toggle('text-on-primary-container');
                marker.classList.toggle('bg-white');
                marker.classList.toggle('text-on-surface');
            }
        });

        // Search bar interaction
        const searchInput = document.querySelector('input[type="text"]');
        if (searchInput) {
            searchInput.addEventListener('focus', () => {
                searchInput.parentElement.classList.add('ring-2', 'ring-primary-container');
            });
            searchInput.addEventListener('blur', () => {
                searchInput.parentElement.classList.remove('ring-2', 'ring-primary-container');
            });
        }
    </script>
</body>

</html>